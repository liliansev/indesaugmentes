---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = "Indés Augmentés · Maîtrise l'IA et l'automation pour scaler ton activité d'indé",
  description = "Bootcamp intensif de 3 mois pour faire de l'IA et l'automation ton levier d'indépendance. Cohorte de 7 personnes, démarrage mi-mai 2026. Accompagnement live avec Lilian Sevoumian.",
} = Astro.props

const siteUrl = 'https://indesaugmentes.com'
const canonicalUrl = new URL(Astro.url.pathname, Astro.site)
const ogImageUrl = `${siteUrl}/og.png`

const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  '@id': `${siteUrl}/#course`,
  name: 'Indés Augmentés · Bootcamp Freelance IA & Automation',
  description:
    "Bootcamp intensif de 3 mois pour devenir freelance augmenté grâce à l'IA, Make et n8n. Positionnement, acquisition clients, outils, accompagnement live en cohorte de 7.",
  url: siteUrl,
  image: ogImageUrl,
  inLanguage: 'fr-FR',
  educationalLevel: 'Beginner to Intermediate',
  teaches: [
    "IA générative appliquée au freelancing",
    "Automation no-code avec Make et n8n",
    "Positionnement et acquisition clients en indépendant",
    "Gestion d'activité freelance (facturation, trésorerie, juridique)",
  ],
  about: ['Intelligence artificielle', 'Automation no-code', 'Freelancing', 'Make', 'n8n'],
  provider: {
    '@type': 'Person',
    '@id': `${siteUrl}/#lilian`,
    name: 'Lilian Sevoumian',
    url: siteUrl,
    sameAs: ['https://www.linkedin.com/in/lilian-sevoumian/'],
  },
  offers: {
    '@type': 'Offer',
    url: 'https://go.indesaugmentes.com/bootcamp',
    price: '1500',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/LimitedAvailability',
    validFrom: '2026-01-01',
    category: 'Cohorte 1 · Prix early adopter',
  },
  hasCourseInstance: {
    '@type': 'CourseInstance',
    name: 'Cohorte 1',
    courseMode: 'Online',
    courseWorkload: 'P12W',
    startDate: '2026-05-15',
    endDate: '2026-08-15',
    location: {
      '@type': 'VirtualLocation',
      url: siteUrl,
    },
    inLanguage: 'fr-FR',
    maximumAttendeeCapacity: 7,
    instructor: {
      '@type': 'Person',
      '@id': `${siteUrl}/#lilian`,
    },
  },
}

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: 'Indés Augmentés',
  legalName: 'AURA GROUP',
  url: siteUrl,
  logo: `${siteUrl}/icon-512.png`,
  email: 'bonjour@liliansevoumian.fr',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '5 Avenue du Maréchal de Lattre de Tassigny',
    postalCode: '94600',
    addressLocality: 'Choisy-le-Roi',
    addressCountry: 'FR',
  },
  taxID: '991735036',
  founder: { '@id': `${siteUrl}/#lilian` },
  sameAs: ['https://www.linkedin.com/in/lilian-sevoumian/'],
}

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  url: siteUrl,
  name: 'Indés Augmentés',
  description,
  inLanguage: 'fr-FR',
  publisher: { '@id': `${siteUrl}/#organization` },
}

const graphSchema = {
  '@context': 'https://schema.org',
  '@graph': [courseSchema, organizationSchema, websiteSchema],
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#7c3aed" />
    <meta name="color-scheme" content="light" />
    <meta name="author" content="Lilian Sevoumian" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Indés Augmentés" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Indés Augmentés · Bootcamp IA & automation pour freelances" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Indés Augmentés · Bootcamp IA & automation pour freelances" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800;900&family=Geist+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=account_balance,calendar_month,check_circle,diversity_3,expand_more,settings_input_component,trending_up,workspace_premium,workspaces&display=swap"
      rel="stylesheet"
    />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(graphSchema)} />

    <!-- DataFast queue (captures goals avant le chargement du script) -->
    <script id="datafast-queue" is:inline>
      window.datafast = window.datafast || function () {
        window.datafast.q = window.datafast.q || []
        window.datafast.q.push(arguments)
      }
    </script>

    <!-- DataFast Analytics (cookieless, proxied via Vercel) -->
    <script
      defer
      data-website-id="dfid_2RpED3CH4DE4gyqbQlZ7T"
      data-domain="indesaugmentes.com"
      data-api-url="/api/dfst-events"
      src="/js/script.js"
      is:inline
    ></script>
  </head>

  <body>
    <a href="#main-content" class="skip-link">Aller au contenu</a>

    <!-- Scroll progress bar -->
    <div id="scroll-progress" class="scroll-progress"></div>

    <!-- Ambient cursor aura -->
    <div id="cursor-aura" class="cursor-aura"></div>

    <!-- NAV -->
    <nav id="navbar" class="nav">
      <div class="inner">
        <a href="#top" class="brand">
          <div class="logo-mark">
            <span class="bar-tall"></span>
            <span class="bar-short"></span>
          </div>
          <span class="wordmark">indés <strong>augmentés</strong></span>
        </a>
        <div class="links">
          <a class="label-mono" href="#diagnostics">Diagnostics</a>
          <a class="label-mono" href="#modules">Modules</a>
          <a class="label-mono" href="#tarifs">Tarifs</a>
          <a href="https://go.indesaugmentes.com/bootcamp" target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-fast-goal="click_cta_navbar">Sécuriser ma place <span class="arr" aria-hidden="true">→</span></a>
        </div>

        <!-- Mobile hamburger -->
        <button
          id="menu-toggle"
          class="menu-toggle"
          aria-label="Ouvrir le menu de navigation"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="mobile-menu" inert>
        <a class="mobile-link" href="#diagnostics">Diagnostics</a>
        <a class="mobile-link" href="#modules">Modules</a>
        <a class="mobile-link" href="#tarifs">Tarifs</a>
        <a href="https://go.indesaugmentes.com/bootcamp" target="_blank" rel="noopener noreferrer" class="mobile-link btn btn-primary" data-fast-goal="click_cta_navbar">Sécuriser ma place <span class="arr" aria-hidden="true">→</span></a>
      </div>
    </nav>

    <main id="main-content" class="content">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer>
      <div class="inner">
        <div>
          <div class="brand">
            <div class="logo-mark">
              <span class="bar-tall"></span>
              <span class="bar-short"></span>
            </div>
            <span class="wordmark">indés <strong>augmentés</strong></span>
          </div>
          <div class="label-mono">© 2026 Lilian Sevoumian. Built for the modern freelance.</div>
        </div>
        <div class="links">
          <a class="label-mono" href="https://www.linkedin.com/in/lilian-sevoumian/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a class="label-mono" href="/mentions-legales/">Mentions légales</a>
          <a class="label-mono" href="/cgv/">CGV</a>
          <a class="label-mono" href="https://go.indesaugmentes.com/bootcamp" target="_blank" rel="noopener noreferrer">Contact</a>
        </div>
      </div>
    </footer>

    <!-- MOBILE STICKY CTA -->
    <div id="sticky-cta" class="sticky-cta">
      <a href="https://go.indesaugmentes.com/bootcamp" target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-fast-goal="click_cta_navbar">Sécuriser ma place <span class="arr" aria-hidden="true">→</span></a>
    </div>

    <script is:inline>
      ;(function () {
        var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

        // --- Hero choreography (fires on first paint, never waits for IntersectionObserver) ---
        var heroSeq = document.querySelector('.hero-seq')
        if (heroSeq) {
          if (prefersReducedMotion) {
            heroSeq.classList.add('is-active')
          } else {
            requestAnimationFrame(function () {
              requestAnimationFrame(function () {
                heroSeq.classList.add('is-active')
              })
            })
          }
        }

        // --- Scroll reveal ---
        if ('IntersectionObserver' in window && !prefersReducedMotion) {
          var revealObs = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in')
                revealObs.unobserve(entry.target)
              }
            })
          }, { threshold: 0.08, rootMargin: '0px 0px -20px 0px' })
          document.querySelectorAll('.reveal').forEach(function (el) { revealObs.observe(el) })
        } else {
          document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('in') })
        }

        // --- Smooth scroll + nav scrolled state + scroll progress + sticky CTA ---
        var navbar = document.getElementById('navbar')
        var progressEl = document.getElementById('scroll-progress')
        var stickyCta = document.getElementById('sticky-cta')

        function handleScroll() {
          var y = window.scrollY
          if (navbar) {
            if (y > 12) navbar.classList.add('scrolled')
            else navbar.classList.remove('scrolled')
          }
          if (progressEl) {
            var h = document.documentElement.scrollHeight - window.innerHeight
            var p = h > 0 ? y / h : 0
            progressEl.style.transform = 'scaleX(' + p + ')'
          }
          if (stickyCta) {
            var pastHero = y > window.innerHeight * 0.8
            var nearBottom = y + window.innerHeight > document.documentElement.scrollHeight - 200
            if (pastHero && !nearBottom) stickyCta.classList.add('show')
            else stickyCta.classList.remove('show')
          }
          // Timeline spine fill: the fill head tracks scroll at a line slightly
          // above viewport center (~42%), so the progression feels slower and the
          // leading edge sits just above what the reader is focusing on.
          var spineEl = document.querySelector('.tl-spine')
          var spineFill = document.querySelector('.tl-spine-fill')
          var tlNodes = document.querySelectorAll('.timeline .tl-node')
          if (spineEl && spineFill && tlNodes.length) {
            var sr = spineEl.getBoundingClientRect()
            var vh2 = window.innerHeight
            var anchorY = vh2 * 0.42
            var headPixels = anchorY - sr.top
            var progress = sr.height > 0 ? Math.max(0, Math.min(1, headPixels / sr.height)) : 0
            spineFill.style.transform = 'scaleY(' + progress + ')'

            var headY = sr.top + progress * sr.height
            for (var ni = 0; ni < tlNodes.length; ni++) {
              var node = tlNodes[ni]
              var nr = node.getBoundingClientRect()
              var nodeCenter = nr.top + nr.height / 2
              if (headY >= nodeCenter) node.classList.add('active')
              else node.classList.remove('active')
            }
          }
        }
        handleScroll()
        window.addEventListener('scroll', handleScroll, { passive: true })
        window.addEventListener('resize', handleScroll, { passive: true })

        document.querySelectorAll('a[href^="#"]').forEach(function (anchor) {
          anchor.addEventListener('click', function (e) {
            var href = this.getAttribute('href')
            if (!href || href === '#') return
            if (href === '#top') {
              e.preventDefault()
              window.scrollTo({ top: 0, behavior: 'smooth' })
              history.pushState(null, '', '#top')
              return
            }
            var target = document.querySelector(href)
            if (!target) return
            e.preventDefault()
            window.scrollTo({
              top: target.getBoundingClientRect().top + window.scrollY - 80,
              behavior: 'smooth'
            })
            history.pushState(null, '', href)
          })
        })

        // --- Mobile menu ---
        var menuToggle = document.getElementById('menu-toggle')
        var mobileMenu = document.getElementById('mobile-menu')
        var isMenuOpen = false
        function toggleMenu(force) {
          if (typeof force === 'boolean') isMenuOpen = force
          else isMenuOpen = !isMenuOpen
          if (!mobileMenu || !menuToggle) return
          mobileMenu.classList.toggle('open', isMenuOpen)
          if (isMenuOpen) mobileMenu.removeAttribute('inert')
          else mobileMenu.setAttribute('inert', '')
          menuToggle.setAttribute('aria-expanded', String(isMenuOpen))
          menuToggle.setAttribute(
            'aria-label',
            isMenuOpen ? 'Fermer le menu de navigation' : 'Ouvrir le menu de navigation'
          )
          var bars = menuToggle.querySelectorAll('span')
          if (bars.length >= 3) {
            if (isMenuOpen) {
              bars[0].style.transform = 'translateY(7px) rotate(45deg)'
              bars[1].style.opacity = '0'
              bars[2].style.transform = 'translateY(-7px) rotate(-45deg)'
            } else {
              bars[0].style.transform = ''
              bars[1].style.opacity = ''
              bars[2].style.transform = ''
            }
          }
        }
        if (menuToggle) menuToggle.addEventListener('click', function () { toggleMenu() })
        document.querySelectorAll('.mobile-link').forEach(function (link) {
          link.addEventListener('click', function () { toggleMenu(false) })
        })
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && isMenuOpen) {
            toggleMenu(false)
            if (menuToggle) menuToggle.focus()
          }
        })

        // --- FAQ accordion ---
        document.querySelectorAll('.faq-item').forEach(function (item) {
          var summary = item.querySelector('.faq-summary')
          if (!summary) return
          summary.addEventListener('click', function () {
            var wasOpen = item.classList.contains('open')
            document.querySelectorAll('.faq-item.open').forEach(function (other) {
              if (other !== item) {
                other.classList.remove('open')
                var otherBtn = other.querySelector('.faq-summary')
                if (otherBtn) otherBtn.setAttribute('aria-expanded', 'false')
              }
            })
            var nowOpen = !wasOpen
            item.classList.toggle('open', nowOpen)
            summary.setAttribute('aria-expanded', String(nowOpen))
          })
        })

        // --- Cursor aura ---
        var aura = document.getElementById('cursor-aura')
        var supportsHover = window.matchMedia('(hover: hover)').matches
        if (aura && supportsHover && !prefersReducedMotion) {
          var mx = window.innerWidth / 2, my = window.innerHeight / 2
          var tx = mx, ty = my
          var auraRunning = false
          function auraLoop() {
            var dx = mx - tx, dy = my - ty
            if (Math.abs(dx) < 0.5 && Math.abs(dy) < 0.5) {
              auraRunning = false
              return
            }
            tx += dx * 0.08
            ty += dy * 0.08
            aura.style.transform = 'translate(' + tx + 'px, ' + ty + 'px)'
            requestAnimationFrame(auraLoop)
          }
          window.addEventListener('mousemove', function (e) {
            mx = e.clientX
            my = e.clientY
            if (!auraRunning) {
              auraRunning = true
              requestAnimationFrame(auraLoop)
            }
          }, { passive: true })
        }

        // --- Terminal chip typewriter ---
        var chipTxt = document.querySelector('.terminal-chip .txt span[data-typewriter]')
        if (chipTxt && !prefersReducedMotion) {
          var strings = [
            'cohorte 1 · 7 places',
            'démarrage · mi-mai 2026',
          ]
          var ci = 0
          function typeNext() {
            var target = strings[ci]
            var k = 0
            chipTxt.textContent = ''
            var iv = setInterval(function () {
              k++
              chipTxt.textContent = target.slice(0, k)
              if (k >= target.length) {
                clearInterval(iv)
                setTimeout(function () {
                  ci = (ci + 1) % strings.length
                  typeNext()
                }, 2400)
              }
            }, 26)
          }
          setTimeout(typeNext, 120)
        }

        // --- Quote typewriter (prompt blinks twice, then text types out) ---
        document.querySelectorAll('[data-typewriter-quote]').forEach(function (el) {
          var promptEl = el.querySelector('.quote-prompt')
          var textEl = el.querySelector('.quote-text')
          if (!promptEl || !textEl) return
          var fullText = textEl.textContent || ''
          if (prefersReducedMotion) return
          textEl.textContent = ''
          var played = false
          function play() {
            if (played) return
            played = true
            var blinkCount = 0
            var blinkTarget = 4
            var blinkIv = setInterval(function () {
              blinkCount++
              promptEl.style.opacity = blinkCount % 2 === 0 ? '1' : '0'
              if (blinkCount >= blinkTarget) {
                clearInterval(blinkIv)
                promptEl.style.opacity = '1'
                el.classList.add('is-typing')
                var k = 0
                var typeIv = setInterval(function () {
                  k++
                  textEl.textContent = fullText.slice(0, k)
                  if (k >= fullText.length) {
                    clearInterval(typeIv)
                    el.classList.remove('is-typing')
                    el.classList.add('is-done')
                  }
                }, 22)
              }
            }, 260)
          }
          if ('IntersectionObserver' in window) {
            var qo = new IntersectionObserver(function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) { play(); qo.disconnect() }
              })
            }, { threshold: 0.5 })
            qo.observe(el)
          } else {
            play()
          }
        })

        // --- DataFast scroll depth tracking ---
        if ('IntersectionObserver' in window) {
          var scrollGoals = { tarifs: 'scroll_to_pricing' }
          var scrollTracked = {}
          var scrollObs = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              var id = entry.target.id
              if (entry.isIntersecting && !scrollTracked[id]) {
                scrollTracked[id] = true
                if (window.datafast) window.datafast(scrollGoals[id])
              }
            })
          }, { threshold: 0.3 })
          Object.keys(scrollGoals).forEach(function (id) {
            var el = document.getElementById(id)
            if (el) scrollObs.observe(el)
          })
        }

        // --- Count-up animation for mentor stats ---
        function easeOutCubic(p) { return 1 - Math.pow(1 - p, 3) }
        document.querySelectorAll('[data-countup]').forEach(function (el) {
          var target = parseInt(el.dataset.countup, 10)
          if (isNaN(target)) return
          var duration = parseInt(el.dataset.duration || '1800', 10)
          var started = false
          function startCount() {
            if (started) return
            started = true
            if (prefersReducedMotion) { el.textContent = target.toLocaleString('fr-FR'); return }
            var t0 = performance.now()
            function tick(t) {
              var p = Math.min(1, (t - t0) / duration)
              var v = Math.round(target * easeOutCubic(p))
              el.textContent = v.toLocaleString('fr-FR')
              if (p < 1) requestAnimationFrame(tick)
            }
            requestAnimationFrame(tick)
          }
          if ('IntersectionObserver' in window) {
            var io = new IntersectionObserver(function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) { startCount(); io.disconnect() }
              })
            }, { threshold: 0.4 })
            io.observe(el)
          } else {
            startCount()
          }
        })
      })()
    </script>
  </body>
</html>
