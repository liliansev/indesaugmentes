---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = "Indés Augmentés — Utilise l'IA et l'automation pour devenir l'indé que tu es",
  description = "Le bootcamp intensif pour devenir freelance en automation et IA en 3 mois. Accompagnement live, cohorte de 5 à 10 personnes, mi-mai 2026.",
} = Astro.props

const canonicalUrl = new URL(Astro.url.pathname, Astro.site)

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'Indés Augmentés — Bootcamp Freelance Automation & IA',
  description: 'Bootcamp de 3 mois pour devenir freelance en automation et IA',
  provider: { '@type': 'Person', name: 'Lilian Sevoumian' },
  offers: { '@type': 'Offer', price: '1500', priceCurrency: 'EUR' },
  duration: 'P12W',
  educationalLevel: 'Beginner to Intermediate',
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a1628" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Indés Augmentés" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&family=Geist+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- DataFast Analytics (cookieless, proxied via Vercel) -->
    <script
      defer
      data-website-id="dfid_2RpED3CH4DE4gyqbQlZ7T"
      data-domain="indesaugmentes.com"
      data-api-url="/api/dfst-events"
      src="/js/script.js"
      is:inline
    ></script>
  </head>

  <body>
    <a href="#main-content" class="skip-link">Aller au contenu</a>

    <!-- Scroll progress bar -->
    <div id="scroll-progress" class="scroll-progress"></div>

    <!-- Ambient cursor aura -->
    <div id="cursor-aura" class="cursor-aura"></div>

    <!-- NAV -->
    <nav id="navbar" class="nav">
      <div class="inner">
        <a href="#top" class="brand">
          <div class="logo-mark">
            <span class="bar-tall"></span>
            <span class="bar-short"></span>
          </div>
          <span class="wordmark">indés <em>augmentés</em></span>
        </a>
        <div class="links">
          <a class="label-mono" href="#diagnostics">Diagnostics</a>
          <a class="label-mono" href="#modules">Modules</a>
          <a class="label-mono" href="#tarifs">Tarifs</a>
          <a href="https://cal.com/lilian-sevoumian/30min" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Réserver mon call <span class="arr">→</span></a>
        </div>

        <!-- Mobile hamburger -->
        <button id="menu-toggle" class="menu-toggle" aria-label="Menu" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="mobile-menu">
        <a class="mobile-link" href="#diagnostics">Diagnostics</a>
        <a class="mobile-link" href="#modules">Modules</a>
        <a class="mobile-link" href="#tarifs">Tarifs</a>
        <a href="https://cal.com/lilian-sevoumian/30min" target="_blank" rel="noopener noreferrer" class="mobile-link btn btn-primary">Réserver mon call <span class="arr">→</span></a>
      </div>
    </nav>

    <main id="main-content" class="content">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer>
      <div class="inner">
        <div>
          <div class="brand">
            <div class="logo-mark">
              <span class="bar-tall"></span>
              <span class="bar-short"></span>
            </div>
            <span class="wordmark">indés <em>augmentés</em></span>
          </div>
          <div class="label-mono">© 2026 Lilian Sevoumian. Built for the modern freelance.</div>
        </div>
        <div class="links">
          <a class="label-mono" href="https://www.linkedin.com/in/lilian-sevoumian/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a class="label-mono" href="#">Mentions légales</a>
          <a class="label-mono" href="https://cal.com/lilian-sevoumian/30min" target="_blank" rel="noopener noreferrer">Contact</a>
        </div>
      </div>
    </footer>

    <!-- MOBILE STICKY CTA -->
    <div id="sticky-cta" class="sticky-cta">
      <a href="https://cal.com/lilian-sevoumian/30min" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Réserver mon call <span class="arr">→</span></a>
    </div>

    <script is:inline>
      ;(function () {
        var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

        // --- Scroll reveal ---
        if ('IntersectionObserver' in window && !prefersReducedMotion) {
          var revealObs = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in')
                revealObs.unobserve(entry.target)
              }
            })
          }, { threshold: 0.12, rootMargin: '0px 0px -80px 0px' })
          document.querySelectorAll('.reveal').forEach(function (el) { revealObs.observe(el) })
        } else {
          document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('in') })
        }

        // --- Smooth scroll + nav scrolled state + scroll progress + sticky CTA ---
        var navbar = document.getElementById('navbar')
        var progressEl = document.getElementById('scroll-progress')
        var stickyCta = document.getElementById('sticky-cta')

        function handleScroll() {
          var y = window.scrollY
          if (navbar) {
            if (y > 12) navbar.classList.add('scrolled')
            else navbar.classList.remove('scrolled')
          }
          if (progressEl) {
            var h = document.documentElement.scrollHeight - window.innerHeight
            var p = h > 0 ? (y / h) * 100 : 0
            progressEl.style.width = p + '%'
          }
          if (stickyCta) {
            var pastHero = y > window.innerHeight * 0.8
            var nearBottom = y + window.innerHeight > document.documentElement.scrollHeight - 200
            if (pastHero && !nearBottom) stickyCta.classList.add('show')
            else stickyCta.classList.remove('show')
          }
          // Timeline spine fill — 0% when timeline top enters viewport,
          // 100% when outcome node reaches 70% viewport from top
          var spine = document.querySelector('.tl-spine-fill')
          var timelineSection = document.querySelector('.timeline')
          var outcomeNode = document.querySelector('.tl-outcome')
          if (spine && timelineSection && outcomeNode) {
            var r = timelineSection.getBoundingClientRect()
            var outcomeR = outcomeNode.getBoundingClientRect()
            var vh = window.innerHeight
            var offsetToOutcome = outcomeR.top - r.top
            var startTop = vh * 0.85
            var endTop = vh * 0.7 - offsetToOutcome
            var progress = Math.max(0, Math.min(1, (startTop - r.top) / (startTop - endTop)))
            spine.style.height = (progress * 100) + '%'
          }
        }
        handleScroll()
        window.addEventListener('scroll', handleScroll, { passive: true })
        window.addEventListener('resize', handleScroll, { passive: true })

        document.querySelectorAll('a[href^="#"]').forEach(function (anchor) {
          anchor.addEventListener('click', function (e) {
            var href = this.getAttribute('href')
            if (!href || href === '#') return
            if (href === '#top') {
              e.preventDefault()
              window.scrollTo({ top: 0, behavior: 'smooth' })
              history.pushState(null, '', '#top')
              return
            }
            var target = document.querySelector(href)
            if (!target) return
            e.preventDefault()
            window.scrollTo({
              top: target.getBoundingClientRect().top + window.scrollY - 80,
              behavior: 'smooth'
            })
            history.pushState(null, '', href)
          })
        })

        // --- Mobile menu ---
        var menuToggle = document.getElementById('menu-toggle')
        var mobileMenu = document.getElementById('mobile-menu')
        var isMenuOpen = false
        function toggleMenu(force) {
          if (typeof force === 'boolean') isMenuOpen = force
          else isMenuOpen = !isMenuOpen
          if (!mobileMenu || !menuToggle) return
          mobileMenu.classList.toggle('open', isMenuOpen)
          menuToggle.setAttribute('aria-expanded', String(isMenuOpen))
          var bars = menuToggle.querySelectorAll('span')
          if (bars.length >= 3) {
            if (isMenuOpen) {
              bars[0].style.transform = 'translateY(7px) rotate(45deg)'
              bars[1].style.opacity = '0'
              bars[2].style.transform = 'translateY(-7px) rotate(-45deg)'
            } else {
              bars[0].style.transform = ''
              bars[1].style.opacity = ''
              bars[2].style.transform = ''
            }
          }
        }
        if (menuToggle) menuToggle.addEventListener('click', function () { toggleMenu() })
        document.querySelectorAll('.mobile-link').forEach(function (link) {
          link.addEventListener('click', function () { toggleMenu(false) })
        })

        // --- FAQ accordion ---
        document.querySelectorAll('.faq-item').forEach(function (item) {
          var summary = item.querySelector('.faq-summary')
          if (!summary) return
          summary.addEventListener('click', function () {
            var wasOpen = item.classList.contains('open')
            document.querySelectorAll('.faq-item.open').forEach(function (other) {
              if (other !== item) other.classList.remove('open')
            })
            item.classList.toggle('open', !wasOpen)
          })
        })

        // --- Cursor aura ---
        var aura = document.getElementById('cursor-aura')
        var supportsHover = window.matchMedia('(hover: hover)').matches
        if (aura && supportsHover && !prefersReducedMotion) {
          var mx = window.innerWidth / 2, my = window.innerHeight / 2
          var tx = mx, ty = my
          window.addEventListener('mousemove', function (e) {
            mx = e.clientX
            my = e.clientY
          }, { passive: true })
          function auraLoop() {
            tx += (mx - tx) * 0.08
            ty += (my - ty) * 0.08
            aura.style.transform = 'translate(' + tx + 'px, ' + ty + 'px)'
            requestAnimationFrame(auraLoop)
          }
          auraLoop()
        }

        // --- Terminal chip typewriter ---
        var chipTxt = document.querySelector('.terminal-chip .txt span[data-typewriter]')
        if (chipTxt && !prefersReducedMotion) {
          var strings = [
            'booking call · 15 min',
            'cohorte 1 · 5 places',
            'démarrage · mi-mai 2026',
            'places restantes · 5/10',
          ]
          var ci = 0
          function typeNext() {
            var target = strings[ci]
            var k = 0
            chipTxt.textContent = ''
            var iv = setInterval(function () {
              k++
              chipTxt.textContent = target.slice(0, k)
              if (k >= target.length) {
                clearInterval(iv)
                setTimeout(function () {
                  ci = (ci + 1) % strings.length
                  typeNext()
                }, 2400)
              }
            }, 26)
          }
          setTimeout(typeNext, 120)
        }

        // --- Count-up animation for mentor stats ---
        function easeOutCubic(p) { return 1 - Math.pow(1 - p, 3) }
        document.querySelectorAll('[data-countup]').forEach(function (el) {
          var target = parseInt(el.dataset.countup, 10)
          if (isNaN(target)) return
          var duration = parseInt(el.dataset.duration || '1800', 10)
          var started = false
          function startCount() {
            if (started) return
            started = true
            if (prefersReducedMotion) { el.textContent = target.toLocaleString('fr-FR'); return }
            var t0 = performance.now()
            function tick(t) {
              var p = Math.min(1, (t - t0) / duration)
              var v = Math.round(target * easeOutCubic(p))
              el.textContent = v.toLocaleString('fr-FR')
              if (p < 1) requestAnimationFrame(tick)
            }
            requestAnimationFrame(tick)
          }
          if ('IntersectionObserver' in window) {
            var io = new IntersectionObserver(function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) { startCount(); io.disconnect() }
              })
            }, { threshold: 0.4 })
            io.observe(el)
          } else {
            startCount()
          }
        })
      })()
    </script>
  </body>
</html>
