---
/* Pricing Section — Single-tier early adopter */
---

<section id="tarifs" class="bg-glacial-bg py-[var(--spacing-section-gap)] relative overflow-hidden">
  <!-- Decorative radial gradient -->
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(79,70,229,0.05)_0%,transparent_70%)]"
    aria-hidden="true"
  ></div>

  <div class="max-w-4xl mx-auto px-6 relative z-10">

    <!-- Pricing card -->
    <div class="relative bg-glacial-panel border border-glacial-surface p-10 md:p-20 overflow-hidden deconstructed-border shadow-2xl pricing-featured">

      <!-- Rotated badge top-right -->
      <div class="absolute top-0 right-0 p-6 rotate-12" aria-hidden="true">
        <div class="bg-cyan text-clinical-dark px-5 py-2 text-xs font-black uppercase tracking-widest font-label">
          COHORTE 1
        </div>
      </div>

      <!-- Header -->
      <div class="mb-16 reveal">
        <span class="eyebrow">Investissement</span>
        <h2 class="mt-8 font-display text-[length:var(--font-size-h1)] font-black uppercase italic leading-[0.9] tracking-tighter text-clinical-dark">
          Tarif Early<br />Adopter.
        </h2>
      </div>

      <!-- Price row -->
      <div class="flex items-baseline gap-8 mb-16 border-b border-glacial-surface pb-12 reveal delay-1">
        <span class="text-7xl md:text-8xl font-black tracking-tighter text-clinical-dark font-display">1&nbsp;500&euro;</span>
        <span class="text-3xl font-bold text-glacial-gray line-through decoration-indigo decoration-4">3&nbsp;000&euro;</span>
      </div>

      <!-- Payment option -->
      <p class="text-on-surface-muted text-base mb-12 reveal delay-2">
        Paiement en 2 fois sans frais : 2 &times; 775&euro;
      </p>

      <!-- Feature list -->
      <div class="flex flex-col gap-6 mb-16">

        <div class="flex items-center gap-6 group reveal delay-2">
          <div class="w-8 h-8 border border-cyan flex items-center justify-center group-hover:bg-cyan transition-colors shrink-0">
            <svg class="w-4 h-4 text-cyan group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="text-lg font-medium text-on-surface">Formation Make compl&egrave;te (valeur 400&euro;)</span>
        </div>

        <div class="flex items-center gap-6 group reveal delay-2">
          <div class="w-8 h-8 border border-cyan flex items-center justify-center group-hover:bg-cyan transition-colors shrink-0">
            <svg class="w-4 h-4 text-cyan group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="text-lg font-medium text-on-surface">Formation n8n compl&egrave;te (valeur 300&euro;)</span>
        </div>

        <div class="flex items-center gap-6 group reveal delay-3">
          <div class="w-8 h-8 border border-cyan flex items-center justify-center group-hover:bg-cyan transition-colors shrink-0">
            <svg class="w-4 h-4 text-cyan group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="text-lg font-medium text-on-surface">24 sessions live en groupe</span>
        </div>

        <div class="flex items-center gap-6 group reveal delay-3">
          <div class="w-8 h-8 border border-cyan flex items-center justify-center group-hover:bg-cyan transition-colors shrink-0">
            <svg class="w-4 h-4 text-cyan group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="text-lg font-medium text-on-surface">2h de coaching individuel avec Lilian</span>
        </div>

        <div class="flex items-center gap-6 group reveal delay-4">
          <div class="w-8 h-8 border border-cyan flex items-center justify-center group-hover:bg-cyan transition-colors shrink-0">
            <svg class="w-4 h-4 text-cyan group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="text-lg font-medium text-on-surface">Acc&egrave;s au SaaS de pilotage freelance</span>
        </div>

        <div class="flex items-center gap-6 group reveal delay-4">
          <div class="w-8 h-8 border border-cyan flex items-center justify-center group-hover:bg-cyan transition-colors shrink-0">
            <svg class="w-4 h-4 text-cyan group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="text-lg font-medium text-on-surface">Call de 30 min avec un expert-comptable</span>
        </div>

        <div class="flex items-center gap-6 group reveal delay-5">
          <div class="w-8 h-8 border border-cyan flex items-center justify-center group-hover:bg-cyan transition-colors shrink-0">
            <svg class="w-4 h-4 text-cyan group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="text-lg font-medium text-on-surface">Acc&egrave;s &agrave; la communaut&eacute; &agrave; vie</span>
        </div>

      </div>

      <!-- CTA -->
      <a href="#cta" class="btn btn-dark btn-lg w-full text-center block text-2xl hover:bg-indigo reveal delay-5">
        R&Eacute;SERVER MA PLACE
      </a>

      <!-- Urgency line -->
      <p class="text-center mt-8 text-indigo font-black font-label text-sm tracking-[0.4em] uppercase reveal delay-6">
        PLACES LIMIT&Eacute;ES &mdash; COHORTE 1
      </p>

    </div>
  </div>
</section>
