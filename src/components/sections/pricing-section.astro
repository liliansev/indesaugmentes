---
/* Pricing Section — Single-tier early adopter | Neon Architect */
---

<section id="tarifs" class="bg-surface py-[var(--spacing-section-gap)] relative overflow-hidden">
  <!-- Decorative radial gradient -->
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(151,169,255,0.05)_0%,transparent_70%)]"
    aria-hidden="true"
  ></div>

  <div class="max-w-2xl mx-auto px-6 relative z-10">

    <!-- Gradient border wrapper -->
    <div class="p-[2px] rounded-2xl bg-gradient-to-br from-primary via-secondary to-primary/50 shadow-[0_0_60px_rgba(151,169,255,0.12)]">
      <div class="bg-surface-container rounded-2xl p-8 md:p-12 lg:p-14 relative overflow-hidden">

        <!-- Eyebrow -->
        <div class="mb-6 reveal">
          <span class="eyebrow">Investissement</span>
        </div>

        <!-- Title — italic, normal-case -->
        <h2 class="font-display text-[length:var(--font-size-h2)] font-bold italic normal-case leading-tight tracking-tight text-on-surface mb-10 reveal delay-1">
          Tarif early adopter
        </h2>

        <!-- Price row -->
        <div class="flex items-baseline gap-4 mb-3 reveal delay-1">
          <span class="text-5xl md:text-6xl font-black tracking-tighter text-on-surface font-display">1&nbsp;500&euro;</span>
          <span class="text-xl md:text-2xl font-semibold text-on-surface-variant line-through decoration-on-surface-variant/50 decoration-2">3&nbsp;000&euro;</span>
        </div>

        <!-- Subtitle under price -->
        <p class="text-on-surface-variant text-sm mb-2 reveal delay-1">
          D&eacute;blocage complet &mdash; acc&egrave;s &agrave; vie
        </p>

        <!-- Payment option -->
        <p class="text-primary text-sm font-medium mb-10 reveal delay-2">
          Paiement en 3 fois disponible
        </p>

        <!-- Divider -->
        <div class="h-px bg-outline-variant/20 mb-8" aria-hidden="true"></div>

        <!-- Feature list with GREEN checkmarks -->
        <div class="flex flex-col gap-4 mb-10">

          <div class="flex items-start gap-4 reveal delay-2">
            <div class="w-6 h-6 rounded-full bg-[#4ade80] flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-on-surface">Formation Make compl&egrave;te (valeur 400&euro;)</span>
          </div>

          <div class="flex items-start gap-4 reveal delay-2">
            <div class="w-6 h-6 rounded-full bg-[#4ade80] flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-on-surface">Formation n8n compl&egrave;te (valeur 300&euro;)</span>
          </div>

          <div class="flex items-start gap-4 reveal delay-3">
            <div class="w-6 h-6 rounded-full bg-[#4ade80] flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-on-surface">24 sessions live en groupe</span>
          </div>

          <div class="flex items-start gap-4 reveal delay-3">
            <div class="w-6 h-6 rounded-full bg-[#4ade80] flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-on-surface">2h de coaching individuel avec Lilian</span>
          </div>

          <div class="flex items-start gap-4 reveal delay-4">
            <div class="w-6 h-6 rounded-full bg-[#4ade80] flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-on-surface">Acc&egrave;s au SaaS de pilotage freelance</span>
          </div>

          <div class="flex items-start gap-4 reveal delay-4">
            <div class="w-6 h-6 rounded-full bg-[#4ade80] flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-on-surface">Call de 30 min avec un expert-comptable</span>
          </div>

          <div class="flex items-start gap-4 reveal delay-5">
            <div class="w-6 h-6 rounded-full bg-[#4ade80] flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-on-surface">Acc&egrave;s &agrave; la communaut&eacute; et Discord priv&eacute;</span>
          </div>

        </div>

        <!-- CTA -->
        <a
          href="https://cal.com/lilian-sevoumian/30min"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-gradient w-full text-center justify-center text-lg md:text-xl py-5 shadow-[0_0_30px_rgba(151,169,255,0.3)] hover:shadow-[0_0_50px_rgba(151,169,255,0.45)] reveal delay-5"
        >
          R&eacute;server ma place maintenant
        </a>

        <!-- Reassurance text -->
        <p class="text-center mt-5 text-on-surface-variant text-sm reveal delay-6">
          La seule formation qui s'occupe de toi, pas seulement de vendre.
        </p>

      </div>
    </div>
  </div>
</section>
