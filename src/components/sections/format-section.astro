---
/* Format Section — Bootcamp structure grid | Neon Architect */
---

<section class="bg-surface py-[var(--spacing-section-gap)]">
  <div class="container-main">

    <!-- Visible headline — italic, centered -->
    <div class="mb-20 text-center">
      <h2 class="font-display text-[length:var(--font-size-h1)] font-bold italic tracking-tight text-on-surface mt-6 normal-case reveal delay-1">
        Un format pens&eacute; pour<br />
        <span class="text-gradient">le passage &agrave; l'action</span>
      </h2>
    </div>

    <!-- 6-cell grid — aligned, no offsets -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

      <!-- Cell 1: Duree -->
      <div class="p-10 bg-surface-container rounded-lg hover:bg-surface-container-high transition-all duration-300 reveal delay-1">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-primary">01. Dur&eacute;e</span>
        <span class="text-3xl font-bold font-display tracking-tighter text-on-surface mb-4 block">12 Semaines</span>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Un parcours progressif pour ancrer les comp&eacute;tences.
        </p>
      </div>

      <!-- Cell 2: Intensite -->
      <div class="p-10 bg-surface-container rounded-lg hover:bg-surface-container-high transition-all duration-300 reveal delay-2">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-secondary">02. Rythme</span>
        <span class="text-3xl font-bold font-display tracking-tighter text-on-surface mb-4 block">Intensif &amp; Flexible</span>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Compatible avec une activit&eacute; en parall&egrave;le.
        </p>
      </div>

      <!-- Cell 3: Format -->
      <div class="p-10 bg-surface-container rounded-lg hover:bg-surface-container-high transition-all duration-300 reveal delay-3">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-primary">03. Format</span>
        <span class="text-3xl font-bold font-display tracking-tighter text-on-surface mb-4 block">100% Distanciel</span>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Acc&egrave;s aux contenus et aux lives depuis n'importe o&ugrave;.
        </p>
      </div>

      <!-- Cell 4: Effectif -->
      <div class="p-10 bg-surface-container rounded-lg hover:bg-surface-container-high transition-all duration-300 reveal delay-4">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-secondary">04. Effectif</span>
        <span class="text-3xl font-bold font-display tracking-tighter text-on-surface mb-4 block">10 Places Max</span>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Accompagnement personnalis&eacute; garanti.
        </p>
      </div>

      <!-- Cell 5: Support -->
      <div class="p-10 bg-surface-container rounded-lg hover:bg-surface-container-high transition-all duration-300 reveal delay-5">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-primary">05. Support</span>
        <span class="text-3xl font-bold font-display tracking-tighter text-on-surface mb-4 block">Acc&egrave;s Direct</span>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Contact direct avec Lilian, r&eacute;ponse en 24h.
        </p>
      </div>

      <!-- Cell 6: Bonus -->
      <div class="p-10 bg-surface-container rounded-lg hover:bg-surface-container-high transition-all duration-300 reveal delay-6">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-secondary">06. R&eacute;seau</span>
        <span class="text-3xl font-bold font-display tracking-tighter text-on-surface mb-4 block">Acc&egrave;s au r&eacute;seau</span>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Acc&egrave;s au r&eacute;seau et aux opportunit&eacute;s du collectif.
        </p>
      </div>

    </div>
  </div>
</section>
