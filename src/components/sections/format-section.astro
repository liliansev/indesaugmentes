---
/* Stats Strip — Key numbers | Light Editorial */
---

<section class="bg-surface-container-low border-y border-outline-variant/30">
  <div class="container-main">
    <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-outline-variant/30">

      <div class="p-8 text-center reveal delay-1">
        <div class="text-primary font-display text-4xl font-bold mb-2">12</div>
        <div class="text-[10px] font-sans text-on-surface-variant uppercase tracking-widest font-bold">Semaines Intensives</div>
      </div>

      <div class="p-8 text-center reveal delay-2">
        <div class="text-on-surface font-display text-4xl font-bold mb-2">6</div>
        <div class="text-[10px] font-sans text-on-surface-variant uppercase tracking-widest font-bold">Places par Cohorte</div>
      </div>

      <div class="p-8 text-center reveal delay-3">
        <div class="text-on-surface font-display text-4xl font-bold mb-2">2</div>
        <div class="text-[10px] font-sans text-on-surface-variant uppercase tracking-widest font-bold">Lives par Semaine</div>
      </div>

      <div class="p-8 text-center reveal delay-4">
        <div class="text-on-surface font-display text-4xl font-bold mb-2">100%</div>
        <div class="text-[10px] font-sans text-on-surface-variant uppercase tracking-widest font-bold">Distanciel</div>
      </div>

    </div>
  </div>
</section>
