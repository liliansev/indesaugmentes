---
/* Format Section — Bootcamp structure grid | Neon Architect */
---

<section class="bg-surface py-[var(--spacing-section-gap)]">
  <div class="container-main">

    <!-- Ghosted headline -->
    <div class="mb-24">
      <h2
        class="font-display text-[length:var(--font-size-h1)] font-black uppercase tracking-tighter text-on-surface/10 reveal"
      >
        Structure du Bootcamp
      </h2>
    </div>

    <!-- 6-cell staggered grid with gap-px reveals -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-outline-variant/10">

      <!-- Cell 1: Duree -->
      <div class="p-14 bg-surface-container hover:bg-surface-container-high transition-all duration-300 reveal delay-1">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-primary">Dur&eacute;e</span>
        <span class="text-3xl font-black font-display tracking-tighter text-on-surface mb-4 block">12 Semaines</span>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Un parcours progressif pour ancrer les comp&eacute;tences.
        </p>
      </div>

      <!-- Cell 2: Intensite (offset +10) -->
      <div class="p-14 bg-surface-container hover:bg-surface-container-high transition-all duration-300 lg:translate-y-10 reveal delay-2">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-secondary">Intensit&eacute;</span>
        <span class="text-3xl font-black font-display tracking-tighter text-on-surface mb-4 block">5-8h / semaine</span>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Compatible avec une activit&eacute; en parall&egrave;le.
        </p>
      </div>

      <!-- Cell 3: Format -->
      <div class="p-14 bg-surface-container hover:bg-surface-container-high transition-all duration-300 reveal delay-3">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-primary">Format</span>
        <span class="text-3xl font-black font-display tracking-tighter text-on-surface mb-4 block">100% En Ligne</span>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Acc&egrave;s aux contenus et aux lives depuis n'importe o&ugrave;.
        </p>
      </div>

      <!-- Cell 4: Effectif (offset -10) -->
      <div class="p-14 bg-surface-container hover:bg-surface-container-high transition-all duration-300 lg:-translate-y-10 reveal delay-4">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-secondary">Effectif</span>
        <span class="text-3xl font-black font-display tracking-tighter text-on-surface mb-4 block">10 Places Max</span>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Accompagnement personnalis&eacute; garanti.
        </p>
      </div>

      <!-- Cell 5: Support (offset +10) -->
      <div class="p-14 bg-surface-container hover:bg-surface-container-high transition-all duration-300 lg:translate-y-10 reveal delay-5">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-primary">Support</span>
        <span class="text-3xl font-black font-display tracking-tighter text-on-surface mb-4 block">Acc&egrave;s Direct</span>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Contact direct avec Lilian, r&eacute;ponse en 24h.
        </p>
      </div>

      <!-- Cell 6: Bonus (offset -10) -->
      <div class="p-14 bg-surface-container hover:bg-surface-container-high transition-all duration-300 lg:-translate-y-10 reveal delay-6">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-secondary">Bonus</span>
        <span class="text-3xl font-black font-display tracking-tighter text-on-surface mb-4 block">Missions</span>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Acc&egrave;s au r&eacute;seau et aux opportunit&eacute;s du collectif.
        </p>
      </div>

    </div>
  </div>
</section>
