---
---

<section id="format">
  <div class="dashboard-panel format-wrap reveal">
    <div class="format-header">
      <div class="label-mono violet eyebrow">05 · Le format</div>
      <h2 class="format-title">Comment ça se passe concrètement</h2>
    </div>

    <div class="format-kpis">
      <div class="kpi">
        <span class="label-mono lab">Durée</span>
        <div class="val">3 mois</div>
        <div class="sub">Intensif</div>
      </div>
      <div class="kpi">
        <span class="label-mono lab">Groupe</span>
        <div class="val">7</div>
        <div class="sub">Max / cohorte</div>
      </div>
      <div class="kpi">
        <span class="label-mono lab">Lives</span>
        <div class="val">1 / sem.</div>
        <div class="sub">Sessions 1h</div>
      </div>
    </div>

    <div class="format-bonus">
      <div class="format-bonus-head">
        <div class="rule"></div>
        <span class="label-mono lime">Ce que tu reçois en plus</span>
        <div class="rule"></div>
      </div>

      <div class="bonus-grid">
        <div class="bonus-card">
          <span class="bonus-prefix" aria-hidden="true">›</span>
          <div class="bonus-text">
            <div class="bonus-title">Mes skills pour m'augmenter</div>
            <div class="bonus-sub">Stack, workflows et prompts que j'utilise au quotidien.</div>
          </div>
        </div>

        <div class="bonus-card">
          <span class="bonus-prefix" aria-hidden="true">›</span>
          <div class="bonus-text">
            <div class="bonus-title">Tous mes projets en open source</div>
            <div class="bonus-sub">Scénarios Make, workflows n8n, automations prêtes à remixer.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
