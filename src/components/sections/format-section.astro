---
/* Format — How it works panel */
---

<section class="mb-24">
  <div class="dashboard-panel p-8 reveal">
    <h2 class="text-xl font-bold mb-8 flex items-center gap-2">
      <span class="material-symbols-outlined text-accent-lime">analytics</span>
      Comment ça se passe concrètement
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div>
        <div class="label-mono">Durée</div>
        <div class="text-lg font-bold text-white">3 mois</div>
        <div class="text-[10px] text-text-dim">Intensif</div>
      </div>
      <div>
        <div class="label-mono">Groupe</div>
        <div class="text-lg font-bold text-white">5-10 pers.</div>
        <div class="text-[10px] text-text-dim">Max cohorte</div>
      </div>
      <div>
        <div class="label-mono">Lives</div>
        <div class="text-lg font-bold text-white">2 / semaine</div>
        <div class="text-[10px] text-text-dim">Sessions de 1h</div>
      </div>
      <div>
        <div class="label-mono">Vidéos</div>
        <div class="text-lg font-bold text-white">Accès illimité</div>
        <div class="text-[10px] text-text-dim">Make + n8n</div>
      </div>
    </div>
    <div class="mt-8 pt-8 border-t border-dash-border grid md:grid-cols-3 gap-6">
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-accent-violet">support_agent</span>
        <span class="text-sm font-medium">2h de coaching 1-to-1</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-accent-violet">dashboard_customize</span>
        <span class="text-sm font-medium">SaaS pilotage trésorerie</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-accent-violet">verified</span>
        <span class="text-sm font-medium">30 min expert-comptable</span>
      </div>
    </div>
  </div>
</section>
