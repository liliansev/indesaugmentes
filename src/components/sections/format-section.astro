---
/* Format Section — Bootcamp structure grid */
---

<section class="bg-glacial-bg py-[var(--spacing-section-gap)]">
  <div class="container-main">

    <!-- Header -->
    <div class="mb-24">
      <h2
        class="font-display text-[length:var(--font-size-h1)] font-black uppercase tracking-tighter text-clinical-dark/10 reveal"
      >
        Structure du Bootcamp
      </h2>
    </div>

    <!-- 6-cell staggered grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-glacial-surface border border-glacial-surface">

      <!-- Cell 1: Dur&eacute;e -->
      <div class="p-14 bg-glacial-panel hover:bg-glacial-surface/20 transition-all reveal delay-1">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-cyan">Dur&eacute;e</span>
        <span class="text-3xl font-black font-display tracking-tighter text-clinical-dark mb-4 block">12 Semaines</span>
        <p class="text-on-surface-muted leading-relaxed text-sm">
          Un parcours progressif pour ancrer les comp&eacute;tences.
        </p>
      </div>

      <!-- Cell 2: Intensit&eacute; (offset +10) -->
      <div class="p-14 bg-glacial-panel hover:bg-glacial-surface/20 transition-all lg:translate-y-10 reveal delay-2">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-indigo">Intensit&eacute;</span>
        <span class="text-3xl font-black font-display tracking-tighter text-clinical-dark mb-4 block">5-8h / semaine</span>
        <p class="text-on-surface-muted leading-relaxed text-sm">
          Compatible avec une activit&eacute; en parall&egrave;le.
        </p>
      </div>

      <!-- Cell 3: Format -->
      <div class="p-14 bg-glacial-panel hover:bg-glacial-surface/20 transition-all reveal delay-3">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-cyan">Format</span>
        <span class="text-3xl font-black font-display tracking-tighter text-clinical-dark mb-4 block">100% En Ligne</span>
        <p class="text-on-surface-muted leading-relaxed text-sm">
          Acc&egrave;s aux contenus et aux lives depuis n'importe o&ugrave;.
        </p>
      </div>

      <!-- Cell 4: Effectif (offset -10) -->
      <div class="p-14 bg-glacial-panel hover:bg-glacial-surface/20 transition-all lg:-translate-y-10 reveal delay-4">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-indigo">Effectif</span>
        <span class="text-3xl font-black font-display tracking-tighter text-clinical-dark mb-4 block">10 Places Max</span>
        <p class="text-on-surface-muted leading-relaxed text-sm">
          Accompagnement personnalis&eacute; garanti.
        </p>
      </div>

      <!-- Cell 5: Support (offset +10) -->
      <div class="p-14 bg-glacial-panel hover:bg-glacial-surface/20 transition-all lg:translate-y-10 reveal delay-5">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-cyan">Support</span>
        <span class="text-3xl font-black font-display tracking-tighter text-clinical-dark mb-4 block">Acc&egrave;s Direct</span>
        <p class="text-on-surface-muted leading-relaxed text-sm">
          Contact direct avec Lilian, r&eacute;ponse en 24h.
        </p>
      </div>

      <!-- Cell 6: Bonus (offset -10) -->
      <div class="p-14 bg-glacial-panel hover:bg-glacial-surface/20 transition-all lg:-translate-y-10 reveal delay-6">
        <span class="text-[10px] font-black font-label uppercase tracking-[0.5em] mb-3 block text-indigo">Bonus</span>
        <span class="text-3xl font-black font-display tracking-tighter text-clinical-dark mb-4 block">Missions</span>
        <p class="text-on-surface-muted leading-relaxed text-sm">
          Acc&egrave;s au r&eacute;seau et aux opportunit&eacute;s du collectif.
        </p>
      </div>

    </div>
  </div>
</section>
