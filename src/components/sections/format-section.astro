---
---

<section>
  <div class="dashboard-panel format-wrap reveal">
    <div class="format-header">
      <div class="format-eyebrow">
        <span class="material-symbols-outlined">calendar_month</span>
        <span class="label-mono lime">Le format</span>
      </div>
      <h3 class="format-title">Comment ça se passe concrètement</h3>
    </div>

    <div class="format-kpis">
      <div class="kpi">
        <span class="label-mono lab">Durée</span>
        <div class="val">3 mois</div>
        <div class="sub">Intensif</div>
      </div>
      <div class="kpi">
        <span class="label-mono lab">Groupe</span>
        <div class="val">7</div>
        <div class="sub">Max / cohorte</div>
      </div>
      <div class="kpi">
        <span class="label-mono lab">Lives</span>
        <div class="val">1 / sem.</div>
        <div class="sub">Sessions 1h</div>
      </div>
      <div class="kpi">
        <span class="label-mono lab">Vidéos</span>
        <div class="val">Accès à vie</div>
        <div class="sub">Make + n8n</div>
      </div>
    </div>

    <div class="format-divider"></div>

    <div class="format-bonus-head">
      <span class="material-symbols-outlined">workspaces</span>
      <span class="label-mono lime">Ce que tu reçois en plus</span>
    </div>

    <div class="bonus-grid">
      <div class="bonus-card">
        <div class="bonus-icon violet">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2c.3 3.5 1.2 5.9 2.7 7.3C16.1 10.8 18.5 11.7 22 12c-3.5.3-5.9 1.2-7.3 2.7C13.2 16.1 12.3 18.5 12 22c-.3-3.5-1.2-5.9-2.7-7.3C7.9 13.2 5.5 12.3 2 12c3.5-.3 5.9-1.2 7.3-2.7C10.8 7.9 11.7 5.5 12 2z" />
          </svg>
        </div>
        <div class="bonus-title">Mes skills pour m'augmenter</div>
        <div class="bonus-sub">Le stack, les workflows, les prompts que j'utilise au quotidien</div>
      </div>

      <div class="bonus-card">
        <div class="bonus-icon white">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.73.5.77 5.46.77 11.73c0 4.95 3.2 9.14 7.64 10.62.56.1.77-.24.77-.54 0-.27-.01-1.16-.02-2.1-3.11.68-3.77-1.33-3.77-1.33-.51-1.29-1.24-1.63-1.24-1.63-1.01-.69.08-.68.08-.68 1.12.08 1.71 1.15 1.71 1.15 1 1.71 2.62 1.22 3.26.93.1-.72.39-1.22.71-1.5-2.48-.28-5.09-1.24-5.09-5.52 0-1.22.44-2.22 1.15-3-.12-.28-.5-1.42.11-2.96 0 0 .94-.3 3.07 1.15.89-.25 1.85-.37 2.8-.37.95 0 1.91.12 2.8.37 2.13-1.45 3.07-1.15 3.07-1.15.61 1.54.23 2.68.11 2.96.71.78 1.15 1.78 1.15 3 0 4.29-2.61 5.24-5.1 5.51.4.35.76 1.03.76 2.08 0 1.5-.01 2.71-.01 3.08 0 .3.2.65.78.54 4.43-1.48 7.63-5.67 7.63-10.62C23.23 5.46 18.27.5 12 .5Z" />
          </svg>
        </div>
        <div class="bonus-title">Tous mes projets en open source</div>
        <div class="bonus-sub">Scénarios Make, workflows n8n, automations prêtes à remixer</div>
      </div>

      <div class="bonus-card">
        <div class="bonus-icon amber">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.296-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.297-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.82 11.82 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.304-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.82 11.82 0 0 0 20.464 3.488" />
          </svg>
        </div>
        <div class="bonus-title">Groupe WhatsApp avec tous les membres</div>
        <div class="bonus-sub">Questions, wins, entraide — accès à vie</div>
      </div>
    </div>
  </div>
</section>
