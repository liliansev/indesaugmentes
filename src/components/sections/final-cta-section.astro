---
/* Final CTA Section — Clean closing block | Neon Architect */
---

<section id="cta" class="py-40 md:py-60 bg-surface relative">

  <div class="container-main text-center relative z-10">

    <!-- Headline -->
    <h2 class="font-display text-[length:var(--font-size-display)] font-bold tracking-tighter leading-[0.85] italic normal-case mb-16 reveal">
      <span class="text-on-surface">Pr&ecirc;t &agrave; passer au</span><br />
      <span class="text-gradient">niveau sup&eacute;rieur ?</span>
    </h2>

    <!-- Subtitle -->
    <p class="text-xl md:text-2xl text-on-surface-variant/60 mb-20 max-w-3xl mx-auto font-light leading-relaxed reveal delay-1">
      R&eacute;serve ton appel de 30 minutes. On discute de ton projet, de tes objectifs, et on v&eacute;rifie ensemble que le bootcamp est fait pour toi.
    </p>

    <!-- CTA area -->
    <div class="flex flex-col items-center gap-12 relative">

      <!-- Ambient light behind button -->
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(151,169,255,0.15)_0%,transparent_60%)] pointer-events-none" aria-hidden="true"></div>

      <!-- Big CTA button -->
      <a
        href="https://cal.com/lilian-sevoumian/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="relative z-10 group btn btn-gradient px-16 py-8 md:px-20 md:py-10 text-2xl md:text-3xl font-black font-display uppercase hover:scale-105 transition-all duration-500 shadow-[0_0_60px_rgba(151,169,255,0.4),0_0_120px_rgba(151,169,255,0.15)] reveal delay-2"
      >
        R&Eacute;SERVER MON APPEL
        <svg class="w-7 h-7 text-secondary group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14" />
          <path d="M12 5l7 7-7 7" />
        </svg>
      </a>

      <!-- Reassurance strip -->
      <div class="relative z-10 flex flex-wrap justify-center gap-16 text-[10px] font-black uppercase tracking-[0.5em] text-on-surface-variant/40 font-label reveal delay-3">
        <span class="flex items-center gap-3">
          <span class="w-2 h-2 rounded-full bg-primary" aria-hidden="true"></span>
          10 Places par cohorte
        </span>
        <span class="flex items-center gap-3">
          <span class="w-2 h-2 rounded-full bg-secondary" aria-hidden="true"></span>
          D&eacute;but : Mai 2026
        </span>
      </div>

    </div>
  </div>
</section>
