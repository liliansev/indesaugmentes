---
/* Final CTA Section — Full dark closing block | Neon Architect */
---

<section id="cta" class="py-40 md:py-60 bg-surface-container-high relative overflow-hidden">

  <!-- Decorative giant background watermark -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none" aria-hidden="true">
    <span class="text-[30rem] md:text-[40rem] font-black leading-none font-display text-on-surface/[0.03] whitespace-nowrap">AUGMENT&Eacute;</span>
  </div>

  <div class="container-main text-center relative z-10">

    <!-- Headline -->
    <h2 class="font-display text-[length:var(--font-size-display)] font-black tracking-tighter leading-[0.8] uppercase italic text-on-surface mb-16 reveal">
      PR&Ecirc;T &Agrave; PASSER<br />
      AU NIVEAU<br />
      <span class="text-gradient">SUP&Eacute;RIEUR ?</span>
    </h2>

    <!-- Subtitle -->
    <p class="text-xl md:text-3xl text-on-surface-variant/60 mb-20 max-w-3xl mx-auto font-light leading-relaxed reveal delay-1">
      R&eacute;serve ton appel de 30 minutes. On discute de ton projet, de tes objectifs, et on v&eacute;rifie ensemble que le bootcamp est fait pour toi.
    </p>

    <!-- CTA area -->
    <div class="flex flex-col items-center gap-12">

      <!-- Big CTA button -->
      <a
        href="https://cal.com/lilian-sevoumian/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="group btn btn-gradient px-16 py-8 md:px-20 md:py-10 text-2xl md:text-3xl font-black font-display uppercase hover:scale-105 transition-all duration-500 shadow-[0_0_50px_rgba(151,169,255,0.3)] reveal delay-2"
      >
        R&Eacute;SERVER MON APPEL
        <svg class="w-7 h-7 text-secondary group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14" />
          <path d="M12 5l7 7-7 7" />
        </svg>
      </a>

      <!-- Info strip -->
      <div class="flex flex-wrap justify-center gap-16 text-[10px] font-black uppercase tracking-[0.5em] text-on-surface-variant/40 font-label reveal delay-3">
        <span class="flex items-center gap-3">
          <span class="w-2 h-2 rounded-full bg-primary" aria-hidden="true"></span>
          10 Places par cohorte
        </span>
        <span class="flex items-center gap-3">
          <span class="w-2 h-2 rounded-full bg-secondary" aria-hidden="true"></span>
          D&eacute;but : Mai 2026
        </span>
      </div>

    </div>
  </div>
</section>
