---
/* Final CTA Section — Clean closing block | Light Editorial */
---

<section id="cta" class="py-40 md:py-60 bg-surface-container-low relative">

  <div class="container-main text-center relative z-10">

    <h2 class="font-display text-[length:var(--font-size-display)] font-bold tracking-tighter leading-[0.85] normal-case mb-16 reveal">
      <span class="text-on-surface">Prêt à passer au</span><br />
      <span class="text-primary">niveau supérieur ?</span>
    </h2>

    <p class="text-xl md:text-2xl text-on-surface-variant/80 mb-20 max-w-3xl mx-auto font-light leading-relaxed reveal delay-1">
      Réserve ton <strong>appel de 30 minutes</strong>. On discute de ton <strong>projet</strong>, de tes <strong>objectifs</strong>, et on vérifie ensemble que le bootcamp est fait pour toi.
    </p>

    <div class="flex flex-col items-center gap-12 relative">

      <a
        href="https://cal.com/lilian-sevoumian/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="relative z-10 group btn btn-gradient px-16 py-8 md:px-20 md:py-10 text-2xl md:text-3xl font-black font-display uppercase hover:scale-105 transition-all duration-500 reveal delay-2"
      >
        RÉSERVER MON APPEL
        <span class="material-symbols-outlined text-white/80 group-hover:translate-x-1 transition-transform duration-300">arrow_forward</span>
      </a>

      <div class="relative z-10 flex flex-wrap justify-center gap-16 text-[10px] font-black uppercase tracking-[0.5em] text-on-surface-variant/80 font-sans reveal delay-3">
        <span class="flex items-center gap-3">
          <span class="w-2 h-2 rounded-full bg-primary" aria-hidden="true"></span>
          6 Places par cohorte
        </span>
        <span class="flex items-center gap-3">
          <span class="w-2 h-2 rounded-full bg-primary" aria-hidden="true"></span>
          Début : Mai 2026
        </span>
      </div>

    </div>
  </div>
</section>
