---
/* Programme Section — 5 pillars overview */
---

<section id="programme" class="bg-glacial-bg py-[var(--spacing-section-gap)]">
  <div class="container-main">

    <!-- Header -->
    <div class="mb-24">
      <span class="eyebrow reveal">Le programme</span>

      <h2
        class="mt-8 font-display text-[length:var(--font-size-h1)] font-black tracking-tighter uppercase italic text-clinical-dark reveal delay-1"
      >
        Le Code de<br />
        <span class="text-indigo">l'Augmentation.</span>
      </h2>

      <!-- Decorative bar -->
      <div class="w-32 h-2 bg-cyan mt-8 reveal delay-2" aria-hidden="true"></div>
    </div>

    <!-- 5-column grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-px bg-glacial-surface border border-glacial-surface">

      <!-- Pillar 1: Architecte Make -->
      <div class="p-10 lg:p-12 bg-glacial-panel hover:bg-glacial-surface/30 transition-all group cursor-default reveal delay-1">
        <div class="text-glacial-gray group-hover:text-cyan transition-colors duration-300 mb-10">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6L20 34" />
            <path d="M20 6L26 16" />
            <path d="M20 6L14 16" />
            <path d="M8 22L32 22" />
            <path d="M12 28L28 28" />
          </svg>
        </div>
        <h3 class="text-xl font-black leading-none text-clinical-dark group-hover:translate-x-1 transition-transform duration-300">
          Architecte Make
        </h3>
        <p class="text-sm text-on-surface-muted opacity-70 mt-4">
          Ma&icirc;trise les sc&eacute;narios d'automatisation de A &agrave; Z.
        </p>
      </div>

      <!-- Pillar 2: Puissance n8n (offset) -->
      <div class="p-10 lg:p-12 lg:translate-y-8 bg-glacial-panel hover:bg-glacial-surface/30 transition-all group cursor-default reveal delay-2">
        <div class="text-glacial-gray group-hover:text-indigo transition-colors duration-300 mb-10">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="6" y="10" width="12" height="8" rx="1" />
            <rect x="22" y="22" width="12" height="8" rx="1" />
            <path d="M18 14L22 26" />
            <path d="M12 18L12 34" />
            <path d="M28 22L28 6" />
          </svg>
        </div>
        <h3 class="text-xl font-black leading-none text-clinical-dark group-hover:translate-x-1 transition-transform duration-300">
          Puissance n8n
        </h3>
        <p class="text-sm text-on-surface-muted opacity-70 mt-4">
          Workflows open-source, auto-h&eacute;berg&eacute;s, sans limites.
        </p>
      </div>

      <!-- Pillar 3: Intelligence IA -->
      <div class="p-10 lg:p-12 bg-glacial-panel hover:bg-glacial-surface/30 transition-all group cursor-default reveal delay-3">
        <div class="text-glacial-gray group-hover:text-cyan transition-colors duration-300 mb-10">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="20" cy="16" r="8" />
            <path d="M12 16C12 16 16 22 20 22C24 22 28 16 28 16" />
            <path d="M20 24L20 30" />
            <path d="M14 30L26 30" />
            <circle cx="17" cy="14" r="1.5" fill="currentColor" stroke="none" />
            <circle cx="23" cy="14" r="1.5" fill="currentColor" stroke="none" />
          </svg>
        </div>
        <h3 class="text-xl font-black leading-none text-clinical-dark group-hover:translate-x-1 transition-transform duration-300">
          Intelligence IA
        </h3>
        <p class="text-sm text-on-surface-muted opacity-70 mt-4">
          Prompting, agents IA, int&eacute;gration dans tes workflows.
        </p>
      </div>

      <!-- Pillar 4: Branding & Offre (offset) -->
      <div class="p-10 lg:p-12 lg:translate-y-8 bg-glacial-panel hover:bg-glacial-surface/30 transition-all group cursor-default reveal delay-4">
        <div class="text-glacial-gray group-hover:text-indigo transition-colors duration-300 mb-10">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="20,6 24,16 34,17 27,24 29,34 20,29 11,34 13,24 6,17 16,16" />
          </svg>
        </div>
        <h3 class="text-xl font-black leading-none text-clinical-dark group-hover:translate-x-1 transition-transform duration-300">
          Branding & Offre
        </h3>
        <p class="text-sm text-on-surface-muted opacity-70 mt-4">
          Positionnement, pricing, personal branding.
        </p>
      </div>

      <!-- Pillar 5: Communaut&eacute; -->
      <div class="p-10 lg:p-12 bg-glacial-panel hover:bg-glacial-surface/30 transition-all group cursor-default reveal delay-5">
        <div class="text-glacial-gray group-hover:text-cyan transition-colors duration-300 mb-10">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="14" cy="14" r="5" />
            <circle cx="26" cy="14" r="5" />
            <path d="M14 19C14 19 8 22 8 26L8 32" />
            <path d="M26 19C26 19 32 22 32 26L32 32" />
            <path d="M20 20C20 20 16 24 16 28L16 34" />
            <path d="M20 20C20 20 24 24 24 28L24 34" />
          </svg>
        </div>
        <h3 class="text-xl font-black leading-none text-clinical-dark group-hover:translate-x-1 transition-transform duration-300">
          Communaut&eacute;
        </h3>
        <p class="text-sm text-on-surface-muted opacity-70 mt-4">
          R&eacute;seau de freelances augment&eacute;s, accountability, partage de deals.
        </p>
      </div>

    </div>
  </div>
</section>
