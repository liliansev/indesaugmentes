---
const timeline = [
  {
    n: 1,
    phase: 'Mois 1',
    variant: 'violet',
    icon: 'settings_input_component',
    title: 'Les outils : Make, n8n & IA',
    body: "Formations vidéo complètes + exercices pratiques. Tu apprends à construire des automations que tu peux vendre en presta, intégrer à ton offre actuelle ou utiliser pour booster ta\u00A0productivité.",
  },
  {
    n: 2,
    phase: 'Mois 1–2',
    variant: 'lime',
    icon: 'trending_up',
    title: 'Le business : te positionner et trouver tes clients',
    body: "Process commercial complet : positionner ton offre augmentée par l'IA, prospecter, closer en call. Les scripts, les templates, tout — que tu vendes de l'IA, du design, du conseil ou autre\u00A0chose.",
  },
  {
    n: 3,
    phase: 'Mois 2',
    variant: 'white',
    icon: 'account_balance',
    title: 'Le quotidien : gérer ton activité',
    body: "Trésorerie, facturation, statut juridique, relation client. Accès à un SaaS de pilotage tréso + un call avec un\u00A0expert-comptable.",
  },
  {
    n: 4,
    phase: 'Mois 2–3',
    variant: 'amber',
    icon: 'diversity_3',
    title: 'Le réseau : tu n\'es plus seul',
    body: "Cohorte de 7\u00A0personnes. 2 lives groupe par semaine. 2h de coaching 1-to-1 avec moi. Un groupe qui te tire vers le\u00A0haut.",
  },
]
---

<section id="modules">
  <div class="programme-head reveal">
    <div class="label-mono violet eyebrow">04 — Le programme</div>
    <h2>3 mois, une trajectoire claire</h2>
    <p>Chaque étape construit la suivante. Tu finis avec une activité qui tient debout.</p>
  </div>

  <div class="timeline">
    <div class="tl-spine"><div class="tl-spine-fill"></div></div>

    {
      timeline.map((step, idx) => (
        <div class={`tl-step reveal d${idx + 1}`}>
          <div class="tl-rail">
            <div class={`tl-node ${step.variant}`}>
              <span class="material-symbols-outlined mat">{step.icon}</span>
              <span class="tl-node-chip">{String(step.n).padStart(2, '0')}</span>
            </div>
          </div>
          <div class="tl-body">
            <div class="tl-meta">
              <span class={`label-mono ${step.variant === 'white' ? 'white' : step.variant}`}>
                Étape {String(step.n).padStart(2, '0')}
              </span>
              <span class="tl-phase">{step.phase}</span>
            </div>
            <div class={`dashboard-panel tl-card ${step.variant}`}>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </div>
          </div>
        </div>
      ))
    }

    <div class="tl-step tl-outcome reveal d5">
      <div class="tl-rail">
        <div class="tl-node outcome">
          <span class="material-symbols-outlined mat">workspace_premium</span>
        </div>
      </div>
      <div class="tl-body">
        <div class="tl-meta">
          <span class="label-mono lime">Résultat · Mois 3</span>
          <span class="tl-phase">Fin du bootcamp</span>
        </div>
        <div class="dashboard-panel tl-card outcome">
          <h3>Bravo, tu es un indépendant augmenté.</h3>
          <p>
            Positionnement clair, premiers clients signés, facturation entre <strong>400€ et 600€/jour</strong>, un réseau solide et les outils pour scaler. Tu as passé le&nbsp;cap.
          </p>
          <div class="tl-kpis">
            <div class="tl-kpi">
              <div class="v">400–600€</div>
              <div class="label-mono">/ jour facturé</div>
            </div>
            <div class="tl-kpi">
              <div class="v">1 offre claire</div>
              <div class="label-mono">positionnée</div>
            </div>
            <div class="tl-kpi">
              <div class="v">Premiers clients</div>
              <div class="label-mono">signés</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
