---
/* Programme Section — 5 pillars, centered header, aligned columns */
---

<section id="programme" class="bg-surface py-[var(--spacing-section-gap)]">
  <div class="container-main">

    <!-- Header (centered) -->
    <div class="text-center mb-20">
      <span class="eyebrow reveal">La transformation</span>
      <h2
        class="font-display text-[length:var(--font-size-display)] font-bold italic tracking-tight text-on-surface mt-6 normal-case reveal delay-1"
      >
        Deviens l'expert indispensable.
      </h2>
      <p class="text-on-surface-variant text-lg max-w-2xl mx-auto mt-6 reveal delay-2">
        En 12 semaines, nous reconstruirons ton arsenal technique et strat&eacute;gique.
      </p>
    </div>

    <!-- 5-column grid (all aligned, no translate-y offset) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">

      <!-- Pillar 1: Architecte Make -->
      <div class="bg-surface-container rounded-lg p-8 reveal delay-1">
        <div class="w-12 h-12 rounded-xl bg-primary/15 flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-primary" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 4L14 24" />
            <path d="M14 4L18 11" />
            <path d="M14 4L10 11" />
            <path d="M6 16L22 16" />
            <path d="M8 20L20 20" />
          </svg>
        </div>
        <h3 class="font-display font-bold text-on-surface mb-3 normal-case">
          Ma&icirc;trise de Make
        </h3>
        <p class="text-on-surface-variant text-sm leading-relaxed">
          Ma&icirc;trise les sc&eacute;narios d'automatisation de A &agrave; Z.
        </p>
      </div>

      <!-- Pillar 2: Puissance n8n -->
      <div class="bg-surface-container rounded-lg p-8 reveal delay-2">
        <div class="w-12 h-12 rounded-xl bg-primary/15 flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-primary" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="4" y="7" width="8" height="6" rx="1" />
            <rect x="16" y="15" width="8" height="6" rx="1" />
            <path d="M12 10L16 18" />
            <path d="M8 13L8 24" />
            <path d="M20 15L20 4" />
          </svg>
        </div>
        <h3 class="font-display font-bold text-on-surface mb-3 normal-case">
          Puissance n8n
        </h3>
        <p class="text-on-surface-variant text-sm leading-relaxed">
          Workflows open-source, auto-h&eacute;berg&eacute;s, sans limites.
        </p>
      </div>

      <!-- Pillar 3: Intelligence IA -->
      <div class="bg-surface-container rounded-lg p-8 reveal delay-3">
        <div class="w-12 h-12 rounded-xl bg-primary/15 flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-primary" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="14" cy="11" r="6" />
            <path d="M8 11C8 11 11 16 14 16C17 16 20 11 20 11" />
            <path d="M14 17L14 21" />
            <path d="M10 21L18 21" />
            <circle cx="12" cy="10" r="1" fill="currentColor" stroke="none" />
            <circle cx="16" cy="10" r="1" fill="currentColor" stroke="none" />
          </svg>
        </div>
        <h3 class="font-display font-bold text-on-surface mb-3 normal-case">
          Intelligence IA
        </h3>
        <p class="text-on-surface-variant text-sm leading-relaxed">
          Prompting, agents IA, int&eacute;gration dans tes workflows.
        </p>
      </div>

      <!-- Pillar 4: Branding & Offre -->
      <div class="bg-surface-container rounded-lg p-8 reveal delay-4">
        <div class="w-12 h-12 rounded-xl bg-primary/15 flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-primary" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="14,4 17,11 24,12 19,17 20,24 14,21 8,24 9,17 4,12 11,11" />
          </svg>
        </div>
        <h3 class="font-display font-bold text-on-surface mb-3 normal-case">
          Branding & Offre
        </h3>
        <p class="text-on-surface-variant text-sm leading-relaxed">
          Positionnement, pricing, personal branding.
        </p>
      </div>

      <!-- Pillar 5: Communaut&eacute; -->
      <div class="bg-surface-container rounded-lg p-8 reveal delay-5">
        <div class="w-12 h-12 rounded-xl bg-primary/15 flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-primary" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="10" cy="10" r="3.5" />
            <circle cx="18" cy="10" r="3.5" />
            <path d="M10 13.5C10 13.5 6 16 6 18.5L6 22" />
            <path d="M18 13.5C18 13.5 22 16 22 18.5L22 22" />
            <path d="M14 14.5C14 14.5 11 17 11 19.5L11 24" />
            <path d="M14 14.5C14 14.5 17 17 17 19.5L17 24" />
          </svg>
        </div>
        <h3 class="font-display font-bold text-on-surface mb-3 normal-case">
          Communaut&eacute;
        </h3>
        <p class="text-on-surface-variant text-sm leading-relaxed">
          R&eacute;seau de freelances augment&eacute;s, accountability, partage de deals.
        </p>
      </div>

    </div>
  </div>
</section>
