---
/* Problem Section — Pain points with skewed background */
---

<section
  id="constat"
  class="section-skew bg-glacial-surface overflow-hidden py-[var(--spacing-section-gap)]"
>
  <div class="section-skew-content">
    <div class="container-main">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">

        <!-- Left: Headline & context -->
        <div>
          <span class="eyebrow reveal">Le constat</span>

          <h2
            class="mt-8 font-display font-black tracking-tighter uppercase text-clinical-dark text-[length:var(--font-size-h1)] reveal delay-1"
          >
            LE FREELANCING<br />
            TRADITIONNEL<br />
            <span class="text-gradient">NE SUFFIT PLUS.</span>
          </h2>

          <p class="mt-10 text-xl text-on-surface-muted font-light leading-relaxed max-w-lg reveal delay-2">
            Le march&eacute; &eacute;volue plus vite que les comp&eacute;tences. L'IA et l'automation ne sont plus des options — c'est la nouvelle base.
          </p>
        </div>

        <!-- Right: Pain point cards -->
        <div class="flex flex-col gap-10">

          <!-- Card 1 -->
          <div class="card-panel group p-12 hover:border-cyan/30 transition-all reveal delay-2">
            <span
              class="block text-5xl font-black text-glacial-surface transition-colors duration-300 group-hover:text-cyan select-none"
              aria-hidden="true"
            >
              01
            </span>
            <h4 class="mt-6 text-xl font-black text-clinical-dark">
              Comp&eacute;tences obsolescentes
            </h4>
            <p class="mt-4 text-on-surface-muted leading-relaxed">
              Tes clients attendent de l'IA et de l'automation, mais tu n'as ni la m&eacute;thode ni les outils pour r&eacute;pondre.
            </p>
          </div>

          <!-- Card 2 -->
          <div class="card-panel group p-12 hover:border-indigo/30 transition-all reveal delay-3">
            <span
              class="block text-5xl font-black text-glacial-surface transition-colors duration-300 group-hover:text-indigo select-none"
              aria-hidden="true"
            >
              02
            </span>
            <h4 class="mt-6 text-xl font-black text-clinical-dark">
              Course aux missions
            </h4>
            <p class="mt-4 text-on-surface-muted leading-relaxed">
              Tu passes plus de temps &agrave; chercher des clients qu'&agrave; livrer des r&eacute;sultats. Sans sp&eacute;cialisation, tu te noies dans la concurrence.
            </p>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>
