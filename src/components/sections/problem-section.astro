---
const diagnostics = [
  {
    n: 1,
    tone: 'violet',
    html: 'Tu as suivi <span class="hi">12 tutos YouTube</span> sur Make, n8n ou l\'IA… mais tu ne sais toujours pas comment l\'utiliser pour ton activité.',
  },
  {
    n: 2,
    tone: 'lime',
    html: 'Tu sais que l\'IA peut transformer ton métier, mais tu vois pas concrètement <span class="hi">comment l\'intégrer à ton offre</span> — ni comment en parler à tes clients.',
  },
  {
    n: 3,
    tone: 'white',
    html: 'Tu as un projet d\'indé en tête depuis des mois. Les autres se lancent, signent, scalent. Toi, tu restes au stade <span class="hi">"side project"</span>.',
  },
  {
    n: 4,
    tone: 'amber',
    html: 'Tu as peut-être un CDI que tu veux quitter, mais tu ne sais pas par <span class="hi">où commencer</span>.',
  },
  {
    n: 5,
    tone: 'violet',
    wide: true,
    html: 'Tu bosses seul, sans feedback, sans réseau, sans personne pour te dire si t\'es sur la <span class="hi">bonne voie</span>.',
  },
]
---

<section id="diagnostics">
  <div class="section-head reveal">
    <span class="label-mono violet" style="font-weight:600">01 — Le constat</span>
    <div class="rule"></div>
  </div>
  <div class="problem-intro">
    <h2 class="reveal d1">Est-ce que tu te reconnais dans cette situation ?</h2>
  </div>
  <div class="problem-grid" data-problem-grid>
    {
      diagnostics.map((d) => (
        <div class={`cell tone-${d.tone}${d.wide ? ' wide' : ''} reveal d${d.n}`} data-cell>
          <span class="label-mono lab">Diagnostic #{d.n}</span>
          <p set:html={d.html} />
        </div>
      ))
    }
  </div>
</section>

<script is:inline>
  ;(function () {
    document.querySelectorAll('[data-cell]').forEach(function (cell) {
      cell.addEventListener('mousemove', function (e) {
        var r = cell.getBoundingClientRect()
        cell.style.setProperty('--mx', ((e.clientX - r.left) / r.width) * 100 + '%')
        cell.style.setProperty('--my', ((e.clientY - r.top) / r.height) * 100 + '%')
      })
    })
  })()
</script>
