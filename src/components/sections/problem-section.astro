---
const diagnostics = [
  {
    n: 1,
    tone: 'violet',
    html: 'Tu as suivi <span class="hi">12 tutos YouTube</span> sur Make, n8n ou l\'IA… mais tu ne sais toujours pas comment l\'utiliser pour ton\u00A0activité.',
  },
  {
    n: 2,
    tone: 'lime',
    html: 'Tu sais que l\'IA peut transformer ton métier, mais tu vois pas concrètement <span class="hi">comment l\'intégrer à ton offre</span>, ni comment en parler à tes\u00A0clients.',
  },
  {
    n: 3,
    tone: 'white',
    html: 'Tu as un projet d\'indé en tête depuis des mois. Les autres se lancent, signent, scalent. Toi, tu restes au stade <span class="hi">"side project"</span>.',
  },
  {
    n: 4,
    tone: 'amber',
    html: 'Tu as peut-être un CDI que tu veux quitter, mais tu ne sais pas par <span class="hi">où commencer</span>.',
  },
  {
    n: 5,
    tone: 'violet',
    wide: true,
    html: 'Tu bosses seul, sans feedback, sans réseau, sans personne pour te dire si t\'es sur la <span class="hi">bonne voie</span>.',
  },
]
---

<section id="diagnostics">
  <div class="problem-left">
    <div class="section-head reveal">
      <span class="label-mono violet" style="font-weight:600">01 · Le constat</span>
      <div class="rule"></div>
    </div>
    <div class="problem-intro">
      <h2 class="reveal d1">Est-ce que tu te reconnais dans cette situation ?</h2>
    </div>
  </div>
  <div class="problem-grid" data-problem-grid>
    {
      diagnostics.map((d) => (
        <div class={`cell tone-${d.tone}${d.wide ? ' wide' : ''} reveal d${d.n}`} data-cell>
          <span class="label-mono lab" data-scramble={`Diagnostic #${d.n}`}>Diagnostic #{d.n}</span>
          <p set:html={d.html} />
        </div>
      ))
    }
  </div>
</section>


<script is:inline>
  ;(function () {
    document.querySelectorAll('[data-cell]').forEach(function (cell) {
      var pending = false
      var lastX = 0, lastY = 0
      cell.addEventListener('mousemove', function (e) {
        lastX = e.clientX
        lastY = e.clientY
        if (pending) return
        pending = true
        requestAnimationFrame(function () {
          pending = false
          var r = cell.getBoundingClientRect()
          cell.style.setProperty('--mx', ((lastX - r.left) / r.width) * 100 + '%')
          cell.style.setProperty('--my', ((lastY - r.top) / r.height) * 100 + '%')
        })
      })
    })

    // --- Text scramble on diagnostic labels ---
    var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    var pool = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789#@%&*+<>/\\'

    function scramble(el, finalText) {
      var len = finalText.length
      var queue = []
      for (var i = 0; i < len; i++) {
        var start = Math.floor(Math.random() * 18)
        var end = start + 18 + Math.floor(Math.random() * 22)
        queue.push({ to: finalText[i], start: start, end: end, char: '' })
      }
      var frame = 0
      function update() {
        var out = ''
        var done = 0
        for (var i = 0; i < queue.length; i++) {
          var q = queue[i]
          if (frame >= q.end) { done++; out += q.to }
          else if (frame >= q.start) {
            if (!q.char || Math.random() < 0.32) {
              q.char = pool.charAt(Math.floor(Math.random() * pool.length))
            }
            out += q.char
          } else {
            out += q.to === ' ' ? ' ' : ' '
            out += q.to === ' ' ? ' ' : ' '
          }
        }
        el.textContent = out
        if (done < queue.length) { frame++; requestAnimationFrame(update) }
      }
      update()
    }

    var labels = document.querySelectorAll('[data-scramble]')
    if (prefersReducedMotion || !('IntersectionObserver' in window)) {
      labels.forEach(function (el) { el.textContent = el.getAttribute('data-scramble') })
      return
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return
        var el = entry.target
        io.unobserve(el)
        scramble(el, el.getAttribute('data-scramble'))
      })
    }, { threshold: 0.6 })
    labels.forEach(function (el) {
      var finalText = el.getAttribute('data-scramble')
      var filler = ''
      for (var i = 0; i < finalText.length; i++) filler += ' '
      for (var i = 0; i < finalText.length; i++) filler += ' '
      el.textContent = filler
      io.observe(el)
    })
  })()
</script>
