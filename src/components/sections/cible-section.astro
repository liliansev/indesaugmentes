---
/* Cible Section — Target audience profiles | Neon Architect dark theme */
---

<section id="cible" class="bg-surface py-[var(--spacing-section-gap)]">
  <div class="container-main">
    <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-10 lg:gap-16 items-start">

      <!-- Left: Title block -->
      <div class="reveal-left">
        <div class="relative bg-surface-container rounded-2xl p-10 lg:p-14 overflow-hidden">
          <!-- Decorative search/user icon -->
          <div class="absolute bottom-6 right-6 text-on-surface-variant/10" aria-hidden="true">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="currentColor">
              <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
              <circle cx="9.5" cy="8" r="1.5"/>
              <path d="M9.5 10.5c-1.38 0-2.5.56-2.5 1.25V12.5h5v-.75c0-.69-1.12-1.25-2.5-1.25z"/>
            </svg>
          </div>

          <h2 class="relative font-display text-[length:var(--font-size-h1)] font-black tracking-tight leading-tight text-on-surface">
            Est-ce que c'est<br />
            <span class="text-gradient italic">pour toi ?</span>
          </h2>

          <p class="relative text-on-surface-variant max-w-sm mt-5 leading-relaxed">
            Tu te reconnais dans un de ces profils ? Alors on a construit ce programme pour toi.
          </p>
        </div>
      </div>

      <!-- Right: 2x2 grid of profiles -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 reveal-right">

        <!-- Profile 1 -->
        <div class="flex items-start gap-4 reveal delay-1">
          <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-3 h-3 text-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <h4 class="text-base font-bold text-on-surface font-display normal-case">Freelances en activit&eacute;</h4>
            <p class="mt-1.5 text-on-surface-variant text-sm leading-relaxed">
              Tu veux ajouter l'IA et l'automation &agrave; ton offre pour facturer plus et livrer plus vite.
            </p>
          </div>
        </div>

        <!-- Profile 2 -->
        <div class="flex items-start gap-4 reveal delay-2">
          <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-3 h-3 text-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <h4 class="text-base font-bold text-on-surface font-display normal-case">Profils en reconversion</h4>
            <p class="mt-1.5 text-on-surface-variant text-sm leading-relaxed">
              Tu quittes un CDI et tu veux te lancer avec une comp&eacute;tence qui recrute.
            </p>
          </div>
        </div>

        <!-- Profile 3 -->
        <div class="flex items-start gap-4 reveal delay-3">
          <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-3 h-3 text-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <h4 class="text-base font-bold text-on-surface font-display normal-case">Consultants &amp; coachs</h4>
            <p class="mt-1.5 text-on-surface-variant text-sm leading-relaxed">
              Tu accompagnes des entreprises et tu veux int&eacute;grer l'automation dans tes prestations.
            </p>
          </div>
        </div>

        <!-- Profile 4 -->
        <div class="flex items-start gap-4 reveal delay-4">
          <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-3 h-3 text-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <h4 class="text-base font-bold text-on-surface font-display normal-case">Agences &amp; &eacute;quipes</h4>
            <p class="mt-1.5 text-on-surface-variant text-sm leading-relaxed">
              Tu veux former ton &eacute;quipe aux outils d'automatisation et d'IA.
            </p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
