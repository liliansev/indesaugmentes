---
import { Image } from 'astro:assets'
import heroImage from '../../assets/hero-image.png'
---

<section class="relative min-h-screen flex items-center bg-surface overflow-hidden pt-24 pb-16 lg:pt-0 lg:pb-0">
  <!-- Decorative blur blobs -->
  <div
    class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-primary/25 blur-[120px] animate-float pointer-events-none"
    aria-hidden="true"
  ></div>
  <div
    class="absolute -bottom-24 -left-24 w-[400px] h-[400px] rounded-full bg-secondary/20 blur-[100px] animate-float pointer-events-none"
    style="animation-delay: -3s;"
    aria-hidden="true"
  ></div>

  <div class="container-main relative z-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">

      <!-- Left: Content (7 cols) -->
      <div class="lg:col-span-7">

        <!-- Badge -->
        <div class="reveal">
          <span class="inline-flex items-center gap-2 font-label uppercase tracking-[0.1em] text-xs font-bold px-4 py-1.5 rounded-md bg-surface-container-high/80 border-l-4 border-primary text-on-surface-variant backdrop-blur-sm">
            <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
            Cohorte 1 &mdash; Places limit&eacute;es
          </span>
        </div>

        <!-- Headline -->
        <h1
          class="mt-10 font-display font-black tracking-tighter leading-[0.85] text-on-surface uppercase text-[length:var(--font-size-display)] reveal delay-1"
        >
          DEVIENS UN<br />
          FREELANCE<br />
          <span class="text-gradient">AUGMENT&Eacute;.</span>
        </h1>

        <!-- Subtitle -->
        <p
          class="mt-10 text-xl lg:text-2xl text-on-surface-variant font-light leading-relaxed max-w-xl border-l border-outline-variant/30 pl-8 reveal delay-2"
        >
          En 3 mois, ma&icirc;trise l'IA et l'automation pour structurer ton offre freelance et d&eacute;crocher tes premi&egrave;res missions.
        </p>

        <!-- Prix + date -->
        <div class="flex flex-wrap items-center gap-6 mt-8 reveal delay-2">
          <span class="font-display font-black text-3xl text-primary">1&nbsp;500&euro;</span>
          <span class="text-outline-variant">|</span>
          <span class="text-on-surface-variant font-medium">D&eacute;but mai 2026</span>
          <span class="text-outline-variant">|</span>
          <span class="text-on-surface-variant font-medium">10 places max</span>
        </div>

        <!-- CTA row -->
        <div class="flex flex-wrap gap-6 mt-10 reveal delay-3">
          <a href="https://cal.com/lilian-sevoumian/30min" target="_blank" rel="noopener noreferrer" class="btn btn-gradient btn-lg">
            R&eacute;server mon appel <span>&rarr;</span>
          </a>
          <a href="#programme" class="btn btn-ghost">
            Voir le programme
          </a>
        </div>

        <!-- Social proof strip -->
        <div class="flex flex-wrap gap-8 mt-12 reveal delay-4">
          <div>
            <span class="block text-3xl font-black text-on-surface leading-none">500+</span>
            <span class="block text-sm text-on-surface-variant mt-1">automatisations d&eacute;ploy&eacute;es</span>
          </div>
          <div class="w-px bg-outline-variant/15 self-stretch" aria-hidden="true"></div>
          <div>
            <span class="block text-3xl font-black text-on-surface leading-none">Make Partner</span>
            <span class="block text-sm text-on-surface-variant mt-1">1er Fran&ccedil;ais certifi&eacute; niveau 5</span>
          </div>
        </div>
      </div>

      <!-- Right: Hero image (5 cols, hidden mobile) -->
      <div class="hidden lg:block lg:col-span-5 reveal-right delay-3">
        <div class="relative">
          <div class="rounded-xl overflow-hidden border border-outline-variant/25 shadow-[0_0_30px_rgba(151,169,255,0.08)]">
            <Image
              src={heroImage}
              alt="Freelances augment&eacute;s par l'IA et l'automation"
              class="w-full h-full object-cover"
              widths={[500, 800]}
              sizes="(max-width: 1024px) 100vw, 40vw"
            />
            <!-- Bottom gradient fade into bg -->
            <div
              class="absolute bottom-0 left-0 right-0 h-1/4 bg-gradient-to-t from-surface to-transparent"
              aria-hidden="true"
            ></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
