---
/* Arsenal Section — What's included | Neon Architect dark theme */
---

<section id="arsenal" class="bg-surface-container py-[var(--spacing-section-gap)] relative">
  <div class="container-main">

    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start mb-24 gap-12">

      <!-- Left -->
      <div class="reveal">
        <span class="eyebrow">L'arsenal</span>
        <h2
          class="font-display text-[length:var(--font-size-h1)] font-black uppercase italic tracking-tighter text-on-surface mt-4"
        >
          Tout ce qui est inclus
        </h2>
        <p class="text-on-surface-variant text-xl max-w-sm mt-4">
          L'&eacute;quipement complet pour devenir op&eacute;rationnel.
        </p>
      </div>

      <!-- Right: Floating value badge -->
      <div class="relative reveal delay-2">
        <!-- Badge -->
        <div
          class="relative bg-surface-container-high text-primary border border-primary/30 px-8 py-5 font-black text-lg tracking-widest font-display flex items-center gap-4 rounded-lg"
        >
          VALEUR : +5&nbsp;000&euro;
          <span class="glow-dot shrink-0" aria-hidden="true"></span>
        </div>
      </div>
    </div>

    <!-- 6-card grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Card 1: Formation Make -->
      <div class="card-glass group relative p-10 overflow-hidden hover:-translate-y-1 transition-all reveal delay-1">
        <div
          class="absolute top-0 right-0 w-20 h-20 bg-primary/5 -translate-y-10 translate-x-10 rotate-45 group-hover:scale-150 transition-transform"
          aria-hidden="true"
        ></div>
        <svg
          width="40"
          height="40"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-primary mb-6"
          aria-hidden="true"
        >
          <path d="M20 6L6 14v12l14 8 14-8V14L20 6z" />
          <path d="M6 14l14 8" />
          <path d="M20 22v12" />
          <path d="M34 14l-14 8" />
          <path d="M13 10l14 8" />
        </svg>
        <h3 class="text-xl font-black mb-4 text-on-surface font-display">
          Formation Make Compl&egrave;te
        </h3>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          De z&eacute;ro &agrave; expert. Sc&eacute;narios avanc&eacute;s, APIs, webhooks, architecture.
        </p>
      </div>

      <!-- Card 2: Formation n8n (offset) -->
      <div class="card-glass group relative p-10 overflow-hidden hover:-translate-y-1 transition-all reveal delay-2 lg:translate-y-8">
        <div
          class="absolute top-0 right-0 w-20 h-20 bg-secondary/5 -translate-y-10 translate-x-10 rotate-45 group-hover:scale-150 transition-transform"
          aria-hidden="true"
        ></div>
        <svg
          width="40"
          height="40"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-secondary mb-6"
          aria-hidden="true"
        >
          <circle cx="10" cy="12" r="4" />
          <circle cx="30" cy="12" r="4" />
          <circle cx="20" cy="28" r="4" />
          <path d="M14 12h12" />
          <path d="M10 16v4a4 4 0 004 4h2" />
          <path d="M30 16v4a4 4 0 01-4 4h-2" />
        </svg>
        <h3 class="text-xl font-black mb-4 text-on-surface font-display">
          Formation n8n Compl&egrave;te
        </h3>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Workflows open-source, self-hosted. D&eacute;ploie sans limites.
        </p>
      </div>

      <!-- Card 3: 2 Lives par Semaine -->
      <div class="card-glass group relative p-10 overflow-hidden hover:-translate-y-1 transition-all reveal delay-3">
        <div
          class="absolute top-0 right-0 w-20 h-20 bg-primary/5 -translate-y-10 translate-x-10 rotate-45 group-hover:scale-150 transition-transform"
          aria-hidden="true"
        ></div>
        <svg
          width="40"
          height="40"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-primary mb-6"
          aria-hidden="true"
        >
          <rect x="4" y="8" width="32" height="24" rx="2" />
          <circle cx="20" cy="20" r="6" />
          <path d="M18 17.5l5 2.5-5 2.5v-5z" fill="currentColor" stroke="none" />
          <circle cx="32" cy="10" r="3" fill="currentColor" stroke="none" />
        </svg>
        <h3 class="text-xl font-black mb-4 text-on-surface font-display">
          2 Lives par Semaine
        </h3>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Sessions tactiques en groupe pour d&eacute;bloquer tes blocages en temps r&eacute;el.
        </p>
      </div>

      <!-- Card 4: Coaching 1-to-1 -->
      <div class="card-glass group relative p-10 overflow-hidden hover:-translate-y-1 transition-all reveal delay-4">
        <div
          class="absolute top-0 right-0 w-20 h-20 bg-secondary/5 -translate-y-10 translate-x-10 rotate-45 group-hover:scale-150 transition-transform"
          aria-hidden="true"
        ></div>
        <svg
          width="40"
          height="40"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-secondary mb-6"
          aria-hidden="true"
        >
          <circle cx="20" cy="14" r="6" />
          <path d="M8 34c0-6.627 5.373-12 12-12s12 5.373 12 12" />
          <path d="M28 18l4-4" />
          <path d="M32 14v4h-4" />
        </svg>
        <h3 class="text-xl font-black mb-4 text-on-surface font-display">
          Coaching 1-to-1
        </h3>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          2h de session individuelle avec Lilian pour aligner ta trajectoire.
        </p>
      </div>

      <!-- Card 5: SaaS de Pilotage (offset) -->
      <div class="card-glass group relative p-10 overflow-hidden hover:-translate-y-1 transition-all reveal delay-5 lg:translate-y-8">
        <div
          class="absolute top-0 right-0 w-20 h-20 bg-primary/5 -translate-y-10 translate-x-10 rotate-45 group-hover:scale-150 transition-transform"
          aria-hidden="true"
        ></div>
        <svg
          width="40"
          height="40"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-primary mb-6"
          aria-hidden="true"
        >
          <rect x="4" y="6" width="32" height="28" rx="2" />
          <path d="M4 14h32" />
          <path d="M12 22l4 4 8-10" />
          <circle cx="10" cy="10" r="1" fill="currentColor" />
          <circle cx="14" cy="10" r="1" fill="currentColor" />
          <circle cx="18" cy="10" r="1" fill="currentColor" />
        </svg>
        <h3 class="text-xl font-black mb-4 text-on-surface font-display">
          SaaS de Pilotage
        </h3>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          Acc&egrave;s &agrave; notre outil interne pour g&eacute;rer ta tr&eacute;sorerie freelance.
        </p>
      </div>

      <!-- Card 6: Call Expert-Comptable -->
      <div class="card-glass group relative p-10 overflow-hidden hover:-translate-y-1 transition-all reveal delay-6">
        <div
          class="absolute top-0 right-0 w-20 h-20 bg-secondary/5 -translate-y-10 translate-x-10 rotate-45 group-hover:scale-150 transition-transform"
          aria-hidden="true"
        ></div>
        <svg
          width="40"
          height="40"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-secondary mb-6"
          aria-hidden="true"
        >
          <path d="M14 6h-2a4 4 0 00-4 4v4a4 4 0 004 4h2" />
          <path d="M26 6h2a4 4 0 014 4v4a4 4 0 01-4 4h-2" />
          <rect x="14" y="4" width="12" height="20" rx="2" />
          <path d="M16 24v4a6 6 0 006 6h0a6 6 0 006-6v-4" />
          <path d="M20 28v6" />
        </svg>
        <h3 class="text-xl font-black mb-4 text-on-surface font-display">
          Call Expert-Comptable
        </h3>
        <p class="text-on-surface-variant leading-relaxed text-sm">
          30 min avec un expert-comptable pour structurer ton activit&eacute;.
        </p>
      </div>

    </div>
  </div>
</section>
